{
  "name": "whatsappd-github-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A continuing Flue Ambience agent for managed WhatsApp chats, with bounded GitHub workflows.",
  "keywords": [
    "ai-agents",
    "flue",
    "ambience",
    "github",
    "whatsapp",
    "whatsappd",
    "chatbot",
    "octokit",
    "typescript"
  ],
  "homepage": "https://github.com/AaronAbuUsama/whatsappd-github-agent#readme",
  "bugs": {
    "url": "https://github.com/AaronAbuUsama/whatsappd-github-agent/issues"
  },
  "license": "MIT",
  "author": "Aaron AbuUsama",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AaronAbuUsama/whatsappd-github-agent.git"
  },
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "flue dev --target node",
    "build": "flue build --target node",
    "start": "node --env-file-if-exists=.env dist/server.mjs",
    "whatsapp:dry-run": "tsx scripts/whatsapp-dry-run.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.2",
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@flue/github": "1.0.0-beta.1",
    "@flue/runtime": "1.0.0-beta.9",
    "@octokit/rest": "^22.0.0",
    "effect": "^3.21.4",
    "hono": "4.12.30",
    "link-preview-js": "^4.0.4",
    "qrcode-terminal": "0.12.0",
    "valibot": "1.4.2",
    "whatsappd": "^0.2.1"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@flue/cli": "1.0.0-beta.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.30"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "baileys",
      "protobufjs"
    ]
  }
}
