{
  "name": "ambient-agent",
  "version": "0.5.0",
  "private": false,
  "description": "Speaker: a continuing ambient agent on Flue for managed WhatsApp chats and authorized GitHub issue management.",
  "keywords": [
    "ai-agents",
    "speaker",
    "chatbot",
    "flue",
    "github",
    "octokit",
    "typescript",
    "whatsapp",
    "whatsappd"
  ],
  "homepage": "https://github.com/AaronAbuUsama/whatsappd-github-agent#readme",
  "bugs": {
    "url": "https://github.com/AaronAbuUsama/whatsappd-github-agent/issues"
  },
  "license": "MIT",
  "author": "Aaron AbuUsama",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AaronAbuUsama/whatsappd-github-agent.git"
  },
  "bin": {
    "ambient-agent": "dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "bundleDependencies": [
    "@flue/runtime"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm start",
    "build": "pnpm run build:server && pnpm run build:cli",
    "build:server": "flue build --target node --root apps/server --output dist",
    "build:cli": "vp pack",
    "changeset": "changeset",
    "prepack": "pnpm run build",
    "release": "pnpm run build && tsx scripts/publish-npm-release.ts",
    "start": "node dist/cli/main.js start",
    "whatsapp:dry-run": "tsx scripts/whatsapp-dry-run.ts",
    "lint": "vp lint .",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "test:watch": "vp test",
    "version-packages": "changeset version",
    "evals": "tsx scripts/run-evals.ts both",
    "evals:deterministic": "tsx scripts/run-evals.ts deterministic",
    "evals:live": "tsx scripts/run-evals.ts live"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "@commander-js/extra-typings": "15.0.0",
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "0.80.2",
    "@flue/github": "1.0.0-beta.1",
    "@flue/runtime": "file:vendor/flue-runtime",
    "@flue/sdk": "1.0.0-beta.9",
    "@hono/node-server": "^2.0.3",
    "@hono/standard-validator": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.0",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@valibot/to-json-schema": "^1.3.0",
    "braintrust": "3.17.0",
    "commander": "15.0.0",
    "effect": "4.0.0-beta.98",
    "hono": "4.12.30",
    "hono-openapi": "^1.3.0",
    "js-yaml": "^4.1.1",
    "just-bash": "^3.0.1",
    "openapi-types": "^12.1.3",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "qrcode-terminal": "0.12.0",
    "quansync": "^0.2.11",
    "ulidx": "^2.4.1",
    "valibot": "1.4.2",
    "whatsappd": "^0.2.1"
  },
  "devDependencies": {
    "@ambient-agent/agents": "workspace:*",
    "@ambient-agent/engine": "workspace:*",
    "@ambient-agent/installation": "workspace:*",
    "@changesets/cli": "2.31.0",
    "@effect/vitest": "4.0.0-beta.98",
    "@flue/cli": "1.0.0-beta.9",
    "@types/json-schema": "7.0.15",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vitest-evals": "0.14.0"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "hono": "4.12.30",
      "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
      "vitest": "4.1.10"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "baileys",
      "protobufjs"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ],
      "allowedVersions": {
        "vite": "*",
        "vitest": "*"
      }
    }
  }
}
