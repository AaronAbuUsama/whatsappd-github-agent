# GitHub access is confined by the application policy below. Prefer a
# fine-grained token limited to the named repositories and required issue scope.
GITHUB_TOKEN=replace-with-scoped-token
GITHUB_REPO=your-org/your-repo
# Defaults to GITHUB_REPO when omitted.
# GITHUB_ALLOWED_REPOS=your-org/your-repo,your-org/another-repo

# Hosted control plane: three GitHub App definitions. Keep the private keys and
# webhook secrets in the deployment secret store, never in the control database.
# GITHUB_APPS_JSON={"coder":{"appId":"1","slug":"ambient-coder","privateKey":"-----BEGIN PRIVATE KEY-----\n...","webhookSecret":"..."},"reviewer":{"appId":"2","slug":"ambient-reviewer","privateKey":"-----BEGIN PRIVATE KEY-----\n...","webhookSecret":"..."},"planner":{"appId":"3","slug":"ambient-planner","privateKey":"-----BEGIN PRIVATE KEY-----\n...","webhookSecret":"..."}}
# Legacy delivery-only fallback when the hosted provisioner is disabled. With
# the provisioner enabled, TENANT_SECRET_ENCRYPTION_KEY derives isolated tenant
# bridge secrets and this duplicate registry is ignored.
# GITHUB_RUNTIME_DELIVERY_SECRETS_JSON={"tenant-id":"runtime-webhook-secret"}

# Hosted tenant provisioner. These values target the existing remote Dokploy
# and Turso control APIs; the API server does not install either service.
# Configure the complete set together. Partial configuration fails startup.
# DOKPLOY_API_URL=https://dokploy.example.com
# DOKPLOY_API_KEY=replace-with-dokploy-api-key
# DOKPLOY_ENVIRONMENT_ID=replace-with-environment-id
# DOKPLOY_SERVER_ID=replace-with-worker-server-id
# DOKPLOY_WORKER_HOSTNAME=replace-with-immutable-swarm-worker-hostname
# DOKPLOY_NETWORK_NAME=dokploy-network
# TENANT_RUNTIME_IMAGE=ghcr.io/your-org/ambient-agent@sha256:replace-with-pinned-digest
# TENANT_RUNTIME_DATA_DIRECTORY=/root/.ambient-agent
# TENANT_RUNTIME_PORT=3000
# TENANT_PROVISIONER_RECONCILE_INTERVAL_MS=5000
# TURSO_ORG=replace-with-turso-organization
# TURSO_GROUP=default
# TURSO_PLATFORM_TOKEN=replace-with-turso-platform-token
# 32 random bytes, base64 encoded. Keep this stable and outside the repository.
# It also derives the isolated runtime bridge secret written only to that
# tenant's Planner credential file and used by the hosted delivery relay.
# TENANT_SECRET_ENCRYPTION_KEY=replace-with-base64-key

# The per-job sandbox both agent shells run in (ADR 0021, #251) is selected in managed config,
# not here: `ambient-agent config --sandbox local|e2b` (default local). The template is
# `runtime.sandbox.template`. Only the E2B key is still operator environment, and only when the
# e2b sandbox is selected; it moves to credentials/e2b.json in #252.
# E2B_API_KEY=replace-with-e2b-api-key

# Verify GitHub webhook signatures before parsing or routing a delivery.
GITHUB_WEBHOOK_SECRET=replace-with-a-high-entropy-secret
# All application-owned state shares this database.
APPLICATION_DB_PATH=./application.sqlite
# Map each repository to the managed WhatsApp chat that owns its events.
# GITHUB_CHAT_ROUTES=your-org/your-repo=1203...@g.us
# A deprecated GITHUB_INGRESS_DB_PATH, or the old ./data/github-ingress.db
# default when present, is imported once and retained as an untouched backup.

# Model authentication is deliberately not configured by environment variable.
# Run `pi /login`, select ChatGPT, and complete OAuth. Ambience requires the
# openai-codex OAuth credential and refuses provider fallback.

# Optional content-bearing Flue traces. Store the API key in the deployment
# secret store; never commit it. Production tracing requires the explicit flag.
# BRAINTRUST_API_KEY=replace-with-non-production-key
# BRAINTRUST_TRACING=1
# BRAINTRUST_PROJECT_NAME=Ambient Agent Evals
# BRAINTRUST_PROJECT_ID=existing-project-id-takes-precedence-over-name
# BRAINTRUST_EXPERIMENT_NAME=optional-name-for-intentional-experiment-append

# Start the in-process whatsappd -> Coalescer -> Ambience production path.
WHATSAPP_STORE_DIR=./.wa-auth
# Defaults to the existing gateway.sqlite so captured history is retained.
# WHATSAPP_HISTORY_DB=./.wa-auth/gateway.sqlite

# Managed chats are fail-closed. Configure one or more group JIDs.
WHATSAPP_GROUP_ID=1203...@g.us
# WHATSAPP_GROUP_IDS=1203...@g.us,1203...@g.us
WHATSAPP_ALLOW_ANY_GROUP=false
WHATSAPP_ALLOW_DM=false

# In LID-addressed groups, provide the bot's LID when WhatsApp mention metadata
# does not use its phone-number JID. A bare number is normalized to @lid.
# WHATSAPP_BOT_LID=1234567890

HOST=0.0.0.0
# PORT=3000
