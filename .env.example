# ── GitHub ──────────────────────────────────────────────────────────────────
# Personal access token (classic or fine-grained) with `repo` scope
# (issues, pull requests, contents, code search) for the repo(s) you want the
# bot to operate on.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default "owner/repo" the GitHub tools operate on when a command doesn't
# name one explicitly (e.g. "list open issues").
GITHUB_REPO=your-org/your-repo

# Write allow-list: the ONLY repos the bot may modify (create/close issues,
# comment, review, label, assign). Comma-separated "owner/repo"; defaults to
# GITHUB_REPO when unset. Reads aren't restricted, but writes to anything
# outside this list are refused — so a chat message like "open an issue in
# someone-else/their-repo" can't turn the bot's token into a write primitive
# against arbitrary repositories.
# GITHUB_ALLOWED_REPOS=your-org/your-repo,your-org/another-repo

# Webhook ingress is verified against the exact raw body before JSON parsing.
# Generate a high-entropy secret and configure the same value on the GitHub webhook.
GITHUB_WEBHOOK_SECRET=change-me
# Explicit repository-to-Ambience ownership. When omitted, the singular
# GITHUB_REPO + WHATSAPP_GROUP_ID pair below forms one route.
# GITHUB_CHAT_ROUTES=your-org/your-repo=1203...@g.us,your-org/another-repo=1203...@g.us
# GITHUB_INGRESS_DB_PATH=./data/github-ingress.db

# ── Model provider — Codex / ChatGPT subscription (NO API KEY) ───────────────
# agent/agent.ts uses eve's native `experimental_chatgpt()` (eve/models/openai),
# which rides your Codex CLI login (OAuth token in ~/.codex/auth.json) and bills
# the ChatGPT subscription. Requirements:
#   • Codex CLI installed and logged in: `codex login`
#   • DELIBERATELY no ANTHROPIC_API_KEY / OPENAI_API_KEY — leave them unset.
# Optional: override the model slug (defaults to eve's current ChatGPT model).
# EVE_MODEL_ID=gpt-5.6-sol

# ── whatsappd sidecar ───────────────────────────────────────────────────────
# One sidecar process = one WhatsApp number. See docs/TUTORIAL.md for pairing.
WHATSAPP_ACCOUNT=default
WHATSAPP_STORE_DIR=./.wa-auth
# Start the paired in-process whatsappd -> Coalescer -> Ambience path.
# Leave unset for build-only or non-WhatsApp runtime processes.
# Do not run the legacy `pnpm whatsapp` sidecar at the same time: one process
# must own this paired account lifecycle.
AMBIENCE_WHATSAPP=1
# Defaults to the existing gateway.sqlite so prior captured history is retained.
# WHATSAPP_HISTORY_DB=./.wa-auth/gateway.sqlite
# Set to pair via a phone-linking code instead of a QR (E.164 format).
# WHATSAPP_PAIRING_PHONE=+15551234567
# Leave PORT UNSET: both the sidecar and `eve dev` read PORT, so setting it
# makes eve grab the sidecar's port. Unset → sidecar = 8788, eve dev = 2000,
# matching the URLs below. (Only set it if you also repoint those URLs.)
# PORT=8788
HOST=0.0.0.0

# The Eve app's WhatsApp channel route the sidecar forwards inbound events
# to. `agent/channels/whatsapp.ts` declares the route as POST("/event", ...),
# and eve mounts a channel's routes at their literal path (no /channels/<name>
# prefix) — so this is the app root + "/event", not a nested path. During
# local dev that's your `eve dev` server (default port 2000).
# Use 127.0.0.1 (not "localhost") — the sidecar binds IPv4, and "localhost"
# resolves to IPv6 (::1) first on many systems, adding a refused-connection hop.
WHATSAPP_FORWARD_URLS=http://127.0.0.1:2000/event

# Shared bearer token both processes use to authenticate sidecar <-> Eve
# traffic. Generate one with `openssl rand -hex 32`.
WHATSAPP_SIDECAR_TOKEN=change-me

# Used by agent/channels/whatsapp.ts to reach the sidecar's HTTP API.
WHATSAPP_SIDECAR_URL=http://127.0.0.1:8788

# ── Group gating (access control — this bot can write to GitHub) ─────────────
# The WhatsApp group JID(s) the bot watches (e.g. "1203630xxxxxxxxx@g.us").
# Find one by adding the bot to a group and reading it off the first inbound
# message (tutorial §7). Use WHATSAPP_GROUP_ID for one group, or
# WHATSAPP_GROUP_IDS for a comma-separated allow-list.
#
# FAIL CLOSED: if neither is set, the bot ignores ALL groups — a misconfig
# silences it rather than opening it to every group the number is in.
WHATSAPP_GROUP_ID=
# WHATSAPP_GROUP_IDS=1203...@g.us,1203...@g.us

# Escape hatch for local experiments only: respond in ANY group (still
# trigger-gated). Leave false in production.
WHATSAPP_ALLOW_ANY_GROUP=false

# Optional second gate: only these senders may trigger the bot. Comma-separated
# phone numbers or JIDs, matched on digits ("+44 7836 603208" and
# "447836603208@s.whatsapp.net" are equivalent). Unset = any member of an
# allowed group may trigger it.
# WHATSAPP_ALLOWED_SENDERS=+15551112222,+447836603208

# The trigger the bot listens for in group messages, case-insensitive
# (e.g. "@github-bot open an issue: ..."). WhatsApp's real @mention metadata
# doesn't cross the sidecar's wire format (see docs/TUTORIAL.md), so this
# plain-text trigger is what "addressed" means here.
WHATSAPP_BOT_TRIGGER=@github-bot

# Direct messages are ignored by default — this bot can create/close issues
# and review PRs, and a WhatsApp number gets messages from anyone. Set to
# "true" only for solo testing before you add the bot to a group.
WHATSAPP_ALLOW_DM=false
