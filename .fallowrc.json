{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "apps/runtime/src/app.ts",
    "packages/agents/evals/*.eval.ts",
    "packages/agents/src/capabilities/*/evals/*.eval.ts",
    "vitest.evals.config.ts",
    "apps/runtime/src/agents/**/*.ts",
    "apps/runtime/src/channels/**/*.ts"
  ],
  "framework": [
    {
      "name": "flue-agent-modules",
      "enablers": [
        "@flue/runtime"
      ],
      "toolingDependencies": [
        "@earendil-works/pi-ai",
        "@octokit/rest",
        "braintrust",
        "pino",
        "pino-roll",
        "valibot"
      ],
      "usedExports": [
        {
          "pattern": "apps/runtime/src/agents/**/*.ts",
          "exports": [
            "description",
            "default"
          ]
        },
        {
          "pattern": "apps/runtime/src/db.ts",
          "exports": [
            "default"
          ]
        }
      ]
    }
  ],
  "ignoreDependencies": [
    "qrcode-terminal"
  ]
}
